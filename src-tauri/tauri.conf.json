{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lil' Hal",
  "version": "0.1.3",
  "identifier": "com.stella.lilhal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Lil' Hal",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0MjgwMzU1OUJFNUIxQTYKUldTbXNlV2JWUU1vaEozVlA3blpCZ0RNTU9HSDl4VVhkY0k2dXZpazYxdzNJcDlhcS9FcEljeUkK",
      "endpoints": [
        "https://github.com/OggieChipped/Lil-Hal/releases/latest/download/latest.json"
      ]
    }
  }
}
